# Dependencies — reinstalled inside the image
node_modules
**/node_modules

# Next.js build output — rebuilt inside the image
.next
**/.next

# Generated plugin directory — recreated by the generate script
runtime/app/plugins

# Non-platform plugins (example + external) are cloned fresh at their pinned refs
# inside the builder (see `pnpm install:plugins`). Never copy a local working-tree
# clone into the context: it is absent from the frozen lockfile and would fail
# `pnpm install --frozen-lockfile` in the deps stage.
plugins/*/
!plugins/account/
!plugins/console/
!plugins/launcher/

# SQLite databases — mounted as a volume so data persists across rebuilds
data/*.db

# Environment files — injected at container runtime, never baked in
.env
.env.local
.env.*.local

# Version control
.git
.gitignore

# Editor artefacts
.vscode
.idea
*.swp
