# Sovereign environment configuration. Copy to .env and adjust.
#
# A single .env at the repo root configures the whole monorepo. Each Next app
# loads it via `loadEnvConfig(repoRoot)` in its next.config.ts — no per-app
# .env files needed. (More variables land with the runtime/deploy tasks.)

# --- Auth server (apps/auth) ---
# AUTH_SECRET has no default — the auth server refuses to start without it.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=
# When true, registration requires a valid invite (the first user is exempt).
AUTH_INVITE_ONLY=false
# Auth identity database — the auth server's own, separate from DATABASE_URL.
# Relative paths resolve against the repo root, so the default lands in the
# root-level data/ directory alongside the platform DB. Override only if needed.
# AUTH_DATABASE_URL=file:./data/auth.db
# Public base URL of the auth server. Set to your domain in production
# (e.g. https://auth.example.com, or https://example.com if auth and runtime
# share a domain). Used by better-auth for callback construction and CSRF origin
# validation. Leave unset for local dev — defaults to http://localhost:3001.
# AUTH_BASE_URL=http://localhost:3001
# Comma-separated list of origins trusted for server-to-server CSRF checks, in
# addition to AUTH_BASE_URL. Set this to the internal Docker service address
# (http://auth:3001) when AUTH_BASE_URL is your public domain, so runtime→auth
# API calls (avatar upload, password change, etc.) are accepted. Not needed for
# native dev (both use localhost:3001).
# AUTH_TRUSTED_ORIGINS=http://auth:3001
# WebAuthn / passkeys (RFC 0012). These only matter if you enable passkeys.
# The defaults work for localhost development. For production, set them to
# your actual domain and origins.
# AUTH_WEBAUTHN_RP_ID=localhost
# AUTH_WEBAUTHN_RP_NAME=Sovereign
# Comma-separated list of allowed WebAuthn origins. Must include BOTH the
# runtime origin (passkey management via proxy) AND the auth server public
# origin (passkey sign-in on the login page). Defaults to both localhost
# ports automatically; in production set to e.g.:
#   AUTH_WEBAUTHN_ORIGIN=https://example.com,https://auth.example.com
# AUTH_WEBAUTHN_ORIGIN=http://localhost:3000,http://localhost:3001

# --- Runtime (runtime/) ---
# Where the runtime reaches the auth server (server-to-server, e.g. /api/verify)
# and where the auth server sends users back after login.
#
# Leave both UNSET for local use: native `pnpm dev` falls back to the localhost
# defaults below, and the Compose files inject the right values per environment
# (dev → :3000/:3001, prod → :4000/:4001 on the host). Setting them here would
# override those per-environment defaults for ALL environments at once.
#
# For a REAL production deployment, set NEXT_PUBLIC_RUNTIME_URL to your public
# runtime URL (e.g. https://example.com). SOVEREIGN_AUTH_URL stays the internal
# address (the Compose files set it to http://auth:3001).
# SOVEREIGN_AUTH_URL=http://localhost:3001
# NEXT_PUBLIC_RUNTIME_URL=http://localhost:3000
# Shared secret for runtime→auth admin API calls (Console user management).
# No default — the auth server and runtime both refuse to start without it.
# Generate one with:  openssl rand -base64 32
SOVEREIGN_ADMIN_KEY=
# Secret for local session verification (SRS AUTH-05). The runtime verifies the
# auth server's signed session cookie offline using this secret — no /api/verify
# round-trip per request — falling back to /api/verify when absent. It MUST equal
# the auth server's signing secret, so it defaults to AUTH_SECRET above; set it
# only if you deliberately run a distinct value.
# SOVEREIGN_AUTH_SECRET=

# --- Diagnostics & dev-mode (RFC 0020) ---
# Structured logging level. Logs go to stdout/stderr only — never egresses
# (see docs/security.md). Values: error | warn (default) | info | debug.
# LOG_LEVEL=warn

# Production dev-mode: lets operators exercise features on a live instance
# against a seeded mock database without touching real user data (RFC 0020).
# Off by default — the feature does not exist unless explicitly enabled.
# SOVEREIGN_DEV_MODE_ENABLED=true
#
# Secret that callers must supply in X-Sovereign-Dev-Mode-Secret to activate
# dev-mode on a request. Falls back to SOVEREIGN_ADMIN_KEY when unset. Must
# not have a default — no-secrets-with-defaults rule.
# SOVEREIGN_DEV_MODE_SECRET=
#
# URL of the mock database populated by `sv seed`. Must be a separate file
# from DATABASE_URL — dev-mode requests read/write only this DB.
# SOVEREIGN_DEV_DATABASE_URL=file:./data/sovereign-dev.db

# --- Database ---
# SQLite by default (zero-config). Relative paths resolve against the repo
# root — all SQLite files land in the root-level data/ directory.
DATABASE_URL=file:./data/sovereign.db
DB_DIALECT=sqlite

# PostgreSQL: point DATABASE_URL + AUTH_DATABASE_URL at a postgres:// URL and set
# DB_DIALECT=postgres. With the Docker stack, layer docker-compose.postgres.yml
# over docker-compose.prod.yml (it provisions a postgres service and wires both
# apps to it) — then only POSTGRES_PASSWORD below is required. See
# docs/self-hosting.md.
# POSTGRES_USER=sovereign
# POSTGRES_PASSWORD=
# POSTGRES_DB=sovereign
# Path to a CA PEM file for Postgres TLS certificate verification. Only used
# when DATABASE_URL / AUTH_DATABASE_URL includes sslmode=verify-full. Uses the
# standard libpq convention (same as the PGSSLROOTCERT env var in psql/pg_dump).
# PGSSLROOTCERT=/path/to/ca.pem

# --- Email (SMTP) ---
# Off by default: with SMTP_HOST unset the mailer no-ops and the app still runs.
# To capture mail in dev, run Mailpit (see CONTRIBUTING — "Email in
# development") and set SMTP_HOST:
#   Docker (app in Compose): SMTP_HOST=mailpit
#   Native / pnpm dev:       SMTP_HOST=localhost
# SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sovereign <dev@localhost>

# Mailpit host-port overrides (optional; defaults 1025 / 8025)
# MAILPIT_SMTP_PORT=1025
# MAILPIT_UI_PORT=8025

# --- Docker Compose ---
# Host port the runtime container is mapped to.
# Default in dev (docker-compose.yml):      3000
# Default in prod (docker-compose.prod.yml): 4000
# RUNTIME_PORT=3000
# Host port the auth server container is mapped to.
# Default in dev (docker-compose.yml):      3001
# Default in prod (docker-compose.prod.yml): 4001
# AUTH_PORT=3001

# Browser-facing URL for auth redirects (login page). In Docker Compose the
# runtime sets SOVEREIGN_AUTH_URL to the internal service name (http://auth:3001),
# which the browser cannot resolve. SOVEREIGN_AUTH_PUBLIC_URL is the host-reachable
# address used for browser redirects only; server-side API calls continue to use
# SOVEREIGN_AUTH_URL. Not needed for native dev (both default to localhost:3001).
# SOVEREIGN_AUTH_PUBLIC_URL=http://localhost:3001

# Note: SOVEREIGN_AUTH_URL above is for native dev (localhost:3001).
# When using Docker Compose, the runtime container overrides this to
# http://auth:3001 (internal Docker network) automatically — do not change
# SOVEREIGN_AUTH_URL for Docker use.

# ── Web Push / VAPID (RFC 0016) ───────────────────────────────────────────────
# Optional. When both keys are set, Sovereign sends background push
# notifications to subscribed browser devices. Leave unset to disable push
# (the in-app bell is the fallback — the app works without push configured).
#
# Generate a VAPID key pair once per deployment with:
#   npx web-push generate-vapid-keys
#
# VAPID_PUBLIC_KEY=<base64url public key>
# VAPID_PRIVATE_KEY=<base64url private key>
# Contact email or URL used in the VAPID Authorization header (required by spec).
# VAPID_CONTACT=mailto:admin@example.com
