# Dependencies
node_modules/

# Build output
dist/
.next/
.turbo/

# Generated plugin route segments are composed under each shell route group
# (e.g. runtime/app/(platform)/(plugins)/) — symlinks in dev, copies in prod.
# A .gitignore inside each group ignores its composed contents. Source of truth
# is always plugins/[id]/app/.

# scripts/generate-registry.ts's output — regenerated by every `pnpm dev`
# startup and by the `pnpm generate` CI step before `pnpm build`. Content is
# a function of whichever plugins happen to be installed in a given checkout
# (community plugins, `.local` dev plugins), so it's inherently
# machine/session-specific — never a meaningful diff to review or commit.
runtime/generated/

# Database files (SQLite) — data/ dirs are created next to each app's cwd
# (root, runtime/, apps/auth/), so match at any depth.
**/data/*.db
**/data/*.db-journal
**/data/*.db-wal
**/data/*.db-shm

# User-uploaded avatars (Account plugin, ACC-03) — runtime data, never committed.
**/data/avatars/

# Plugin-isolated databases and runtime assets written to data/plugins/ by the
# plugin DB provisioner — runtime data, never committed.
**/data/plugins/

# Externally-installed plugins (cloned by scripts/install-plugins.ts) are not
# committed here — they live in their own repositories. Ignore every plugin
# directory except the platform plugins that ship in this monorepo. The example
# plugins live in sovereignfs/sovereign-plugins-examples and are cloned in by
# scripts/install-plugins.ts (see sovereign.plugins.json), so they are ignored
# here too.
/plugins/*/
!/plugins/account/
!/plugins/console/
!/plugins/launcher/

# Personal list of plugin repos to clone as plugins/<name>.local (read by
# setup.sh). Developer-specific and never committed — see setup.sh header.
/sovereign.plugins.local

# PWA service worker + Workbox bundles, generated into runtime/public by
# @ducanh2912/next-pwa at build time. Never committed (the manifest + icons are).
runtime/public/sw.js
runtime/public/sw.js.map
runtime/public/workbox-*.js
runtime/public/workbox-*.js.map
runtime/public/fallback-*.js
runtime/public/worker-*.js

# Local / private working area. Not part of the open-source monorepo — may hold
# proprietary plugin specs and notes, typically backed by a separate private
# repository initialised inside it. Never committed here.
/local/

# Environment / secrets
.env
.env.*
!.env.example

# Claude Code — ignore per-machine/local files; shared config (settings.json,
# commands/, agents/) may be committed. launch.json is a local dev-server
# convenience (mirrors `pnpm dev`), kept out of the shared repo.
.claude/settings.local.json
.claude/launch.json
# Ephemeral git worktrees created by spawned/isolated agent tasks — must never
# be tracked or scanned by tooling (format/lint checks would otherwise pick up
# another in-progress session's uncommitted work as if it were part of this one).
.claude/worktrees/

# Claude Code memory — private persistent context for the AI assistant.
# Machine-local; never committed (would conflict across sessions/users).
memory/

# Codex — ignore per-machine/local logs and overrides. Shared repo guidance
# (`AGENTS.md`) and repo skills (`.agents/skills/`) are committed.
.codex-log/
.codex/*.local.*
.codex/AGENTS.override.md

# OS
.DS_Store

# Playwright E2E
playwright-report/
test-results/
.auth/

# Storybook
packages/ui/storybook-static/

# VitePress
apps/docs/.vitepress/cache/
apps/docs/--host/

# pnpm local store (should live in ~/.local/share/pnpm or equivalent, not the repo)
.pnpm-store/

# Local session working file — never commit
CURRENT_TASK.md
storybook.log
packages/ui/debug-storybook.log
