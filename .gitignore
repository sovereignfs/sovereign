# Dependencies
node_modules/

# Build output
dist/
.next/
.turbo/

# Generated plugin route segments are composed under each shell route group
# (e.g. runtime/app/(platform)/(plugins)/) — symlinks in dev, copies in prod.
# A .gitignore inside each group ignores its composed contents. Source of truth
# is always plugins/[id]/app/.

# Database files (SQLite) — data/ dirs are created next to each app's cwd
# (root, runtime/, apps/auth/), so match at any depth.
**/data/*.db
**/data/*.db-journal
**/data/*.db-wal
**/data/*.db-shm

# User-uploaded avatars (Account plugin, ACC-03) — runtime data, never committed.
**/data/avatars/

# Externally-installed plugins (cloned by scripts/install-plugins.ts) are not
# committed here — they live in their own repositories. Ignore every plugin
# directory except the platform plugins that ship in this monorepo.
/plugins/*/
!/plugins/account/
!/plugins/console/
!/plugins/launcher/
!/plugins/example-basic/
!/plugins/example-api/
!/plugins/example-monetized/

# PWA service worker + Workbox bundles, generated into runtime/public by
# @ducanh2912/next-pwa at build time. Never committed (the manifest + icons are).
runtime/public/sw.js
runtime/public/sw.js.map
runtime/public/workbox-*.js
runtime/public/workbox-*.js.map
runtime/public/fallback-*.js

# Local / private working area. Not part of the open-source monorepo — may hold
# proprietary plugin specs and notes, typically backed by a separate private
# repository initialised inside it. Never committed here.
/local/

# Environment / secrets
.env
.env.*
!.env.example

# Claude Code — ignore per-machine/local files; shared config (settings.json,
# commands/, agents/) may be committed. launch.json is a local dev-server
# convenience (mirrors `pnpm dev`), kept out of the shared repo.
.claude/settings.local.json
.claude/launch.json

# Claude Code memory — private persistent context for the AI assistant.
# Machine-local; never committed (would conflict across sessions/users).
memory/

# OS
.DS_Store

# Playwright E2E
playwright-report/
test-results/
.auth/

# Storybook
packages/ui/storybook-static/

# Local session working file — never commit
CURRENT_TASK.md
storybook.log
packages/ui/debug-storybook.log
