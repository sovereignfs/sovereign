# Hoist Vue to the root node_modules so VitePress's SSR bundle can resolve
# vue/server-renderer when compiling markdown pages. Without this, pnpm's
# strict isolation puts vue only inside VitePress's own node_modules subtree,
# but Rollup resolves it from the docs/ srcDir context which has no vue.
public-hoist-pattern[]=vue
public-hoist-pattern[]=@vue/*
