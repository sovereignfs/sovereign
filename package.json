{
  "name": "sovereign",
  "version": "0.37.0",
  "private": true,
  "type": "module",
  "description": "Sovereign — a modular, self-hostable workspace runtime.",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=!@sovereignfs/docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo typecheck",
    "design:tokens:check": "tsx scripts/design-tokens-check.ts",
    "docs:check-links": "tsx scripts/check-doc-links.ts",
    "verify:push": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm design:tokens:check && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --reporter=verbose",
    "test:integration": "vitest run __tests__/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:all": "vitest run && vitest run __tests__/integration --passWithNoTests && playwright test",
    "kill-port": "bash -c 'for port in 3000 3001; do pid=$(lsof -nP -iTCP:$port -sTCP:LISTEN 2>/dev/null | grep LISTEN | awk \"{print \\$2}\" | head -1); if [ -n \"$pid\" ]; then kill -9 $pid && echo \"Port $port freed (PID $pid)\"; else echo \"Port $port is already free\"; fi; done'",
    "generate": "tsx scripts/generate-registry.ts",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "generate:splash": "tsx scripts/generate-splash.ts",
    "install:plugins": "tsx scripts/install-plugins.ts",
    "registry:validate": "tsx scripts/validate-registry.ts",
    "registry:check": "tsx scripts/validate-registry.ts --check",
    "validate:plugin-boundary": "tsx scripts/validate-plugin-boundary.ts",
    "sv": "tsx bin/sv.ts",
    "storybook": "pnpm --filter @sovereignfs/ui storybook",
    "build-storybook": "pnpm --filter @sovereignfs/ui build-storybook",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm validate:plugin-boundary",
    "pre-push": "pnpm verify:push"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{js,mjs,cjs,json,jsonc,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.61.0",
    "@sovereignfs/db": "workspace:*",
    "@sovereignfs/manifest": "workspace:*",
    "@sovereignfs/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "better-auth": "^1.6.16",
    "better-sqlite3": "^12.10.0",
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^15.14.0",
    "jiti": "^2.4.2",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.3.0",
    "lucide": "^1.21.0",
    "prettier": "^3.5.0",
    "sharp": "0.34.5",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.8",
    "vue": "^3.5.39"
  }
}
