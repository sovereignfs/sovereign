{
  "name": "@sovereignfs/create-plugin",
  "version": "0.1.1",
  "description": "Scaffold a new Sovereign plugin — run via `npm create @sovereignfs/plugin`",
  "keywords": [
    "sovereign",
    "plugin",
    "scaffold",
    "create",
    "cli",
    "template",
    "self-hosted"
  ],
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "create-plugin": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@sovereignfs/tsconfig": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
