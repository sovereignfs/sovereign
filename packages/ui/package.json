{
  "name": "@sovereignfs/ui",
  "version": "0.20.0",
  "type": "module",
  "description": "Sovereign Design System — design tokens and React components.",
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./tokens.css": "./dist/tokens.css",
      "./tokens/primitives.css": "./dist/tokens/primitives.css",
      "./tokens/semantic.css": "./dist/tokens/semantic.css"
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens.css",
    "./tokens/primitives.css": "./src/tokens/primitives.css",
    "./tokens/semantic.css": "./src/tokens/semantic.css"
  },
  "files": [
    "dist",
    "src",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@sovereignfs/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/addon-themes": "catalog:storybook",
    "@storybook/react-vite": "catalog:storybook",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "catalog:storybook",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
