# Generated by scripts/generate-registry.ts — composed plugin route segments
# (copies). Never commit these. The source of truth is always plugins/<id>/app/.
# This .gitignore anchors the route group so the App Router can compose minimal
# (chrome-free) plugins under the session-gated middleware.
#
# The committed files below are hand-written, NOT generated:
#   - layout.tsx         chrome-free full-bleed layout (RFC 0014)
#   - minimal.module.css layout styles
/*
!/.gitignore
!/layout.tsx
!/minimal.module.css
