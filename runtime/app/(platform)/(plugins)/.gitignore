# Generated by scripts/generate-registry.ts — composed plugin route segments
# (copies). Never commit these. The source of truth is always plugins/<id>/app/.
# This .gitignore anchors the route group so the App Router can compose plugins
# under the platform shell.
#
# The committed exceptions below are hand-written, NOT generated:
#   - layout.tsx           hosts the @modal overlay slot (RFC 0001)
#   - @modal/default.tsx   empty-slot fallback
#   - @modal/layout.tsx    Dialog chrome for intercepted overlay plugins
# The generated overlay interception copies (@modal/(.)<routePrefix>) stay
# ignored.
/*
!/.gitignore
!/layout.tsx
!/@modal
/@modal/*
!/@modal/default.tsx
!/@modal/layout.tsx
