{
  "extends": "@sovereignfs/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "middleware.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "generated/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "app/(platform)/(plugins)/**", "app/(minimal)/**"]
}
